{
  "manifest_version": 3,
  "name": "Tubes3 Stosa",
  "version": "1.0.0",
  "description": "A Chrome extension built with React, TypeScript, and Vite.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
